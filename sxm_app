#!/bin/bash
# Single command to run SatStash
# Usage: ./sxm_app

cd "$(dirname "$0")"

# Create venv if it doesn't exist
if [ ! -d "venv" ]; then
    echo "🔧 First time setup..."
    echo "Creating virtual environment..."
    python3 -m venv venv
fi

source venv/bin/activate

# Install dependencies if needed
if ! python -c "import playwright, PIL" 2>/dev/null; then
    echo "📦 Installing dependencies..."
    pip install -q mutagen requests playwright python-Levenshtein textual fuzzywuzzy rich Pillow
    echo "🌐 Installing browser..."
    playwright install chromium
fi

# Run the CLI
clear
echo "╔════════════════════════════════════════════════════════════╗"
echo "║              📻 SatStash - Simple & Working!              ║"
echo "╚════════════════════════════════════════════════════════════╝"

python sxm_cli.py "$@"
